{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/main/.schema/devbox.schema.json",
  "packages": [
    "go@1.25",
    "gnumake@latest",
    "flutter@latest"
  ],
  "env": {
    "PATH": "$HOME/go/bin:$PATH"
  },
  "shell": {
    "init_hook": [
      "printf '✓ forgify devbox ready — go=%s\\n' \"$(go version | awk '{print $3}')\""
    ]
  }
}
