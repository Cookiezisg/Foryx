{
  "name": "forgify-testend",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Forgify dev control panel — comprehensive debugging UI for the V1.2 backend",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "build:nocheck": "vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "cytoscape": "^3.30.0",
    "pinia": "^2.2.6",
    "vue": "^3.5.13",
    "vue-i18n": "^10.0.8",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@types/cytoscape": "^3.21.7",
    "@vitejs/plugin-vue": "^5.2.1",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vue-tsc": "^2.1.10"
  }
}
